{
  "manifest_version": 3,
  "name": "Div Text Extractor",
  "version": "1.0",
  "description": "Select multiple divs and copy their cleaned text to the clipboard.",
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite",
    "clipboardRead",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["ai/ai-processor.js", "recorder/recorder.js", "content/paste-assistant.js"],
      "css": ["content/paste-assistant.css"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}

